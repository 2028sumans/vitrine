{
  "manifest_version": 3,
  "name": "Muse — Find its Twin",
  "short_name": "Muse Twin",
  "description": "Right-click any image on the web. Get its Back Catalogue twin from an independent label.",
  "version": "0.1.0",

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Muse — Find its Twin"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "contextMenus",
    "sidePanel",
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
